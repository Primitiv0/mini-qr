# Environment variables for MiniQR

# Crowdin configuration for translations
CROWDIN_PERSONAL_TOKEN="your_personal_token"
CROWDIN_PROJECT_ID="your_project_id"

# Base path for deployment (e.g., /mini-qr for deploying at domain.com/mini-qr)
# Default: ./ (relative paths, works at any sub-path without configuration)
BASE_PATH=/mini-qr

VITE_HIDE_CREDITS=false
VITE_DEFAULT_PRESET=plain
VITE_DEFAULT_DATA_TO_ENCODE=
VITE_QR_CODE_PRESETS=
VITE_FRAME_PRESET=
VITE_FRAME_PRESETS=
VITE_DISABLE_LOCAL_STORAGE=false
VITE_ENABLE_ANALYTICS=false

# Show the Simple/Full mode toggle + "Customize fields" button. Default false
# (hidden) so self-hosted deployments aren't exposed to it unless opted in.
VITE_QR_CREATE_SIMPLE_FULL_MODE_TOGGLE=false
# Comma-separated field keys to show. When set, the app starts in Simple mode
# showing only the data field + these fields (e.g. dotsColor,frameText). Leave
# empty for the normal full-config experience.
VITE_FIELDS_VISIBLE=
